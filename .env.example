# AI Dev Team — 환경변수 템플릿
# 이 파일을 .env로 복사한 후 값을 입력하세요.
# cp .env.example .env

# ── AI API ──
GEMINI_API_KEY=            # Google AI Studio에서 발급 (필수)

# ── Notion (보고 시스템) ──
NOTION_API_KEY=            # Notion Integration 토큰 (필수)
NOTION_TASK_DB_ID=         # 태스크 DB ID
NOTION_PROJECT_DB_ID=      # 프로젝트 DB ID
NOTION_DECISION_DB_ID=     # 의사결정 DB ID
NOTION_TECHREF_DB_ID=      # 기술레퍼런스 DB ID

# ── Slack (알림) ──
SLACK_WEBHOOK_URL=         # Slack Incoming Webhook URL (필수)
SLACK_CHANNEL=ai-dev-team  # 알림 채널명

# ── 프로젝트별 (선택) ──
# PORTFIQ_GEMINI_API_KEY=  # Portfiq 전용 Gemini 키 (사용량 분리 추적)
# PORTFIQ_SUPABASE_URL=
# PORTFIQ_SUPABASE_ANON_KEY=
# PORTFIQ_SUPABASE_SERVICE_KEY=
